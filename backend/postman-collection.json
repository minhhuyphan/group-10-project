{
  "info": {
    "name": "User Management - Refresh Token API",
    "description": "Complete API collection for testing Refresh Token & Session Management (SV3 - Database)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "1. Signup",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "http://localhost:3001/auth/signup",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3001",
              "path": ["auth", "signup"]
            },
            "description": "Register a new user account. Returns accessToken and refreshToken."
          },
          "response": [
            {
              "name": "Success Response",
              "originalRequest": {
                "method": "POST",
                "url": {
                  "raw": "http://localhost:3001/auth/signup"
                }
              },
              "status": "Created",
              "code": 201,
              "_postman_previewlanguage": "json",
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "body": "{\n  \"success\": true,\n  \"message\": \"Đăng ký thành công\",\n  \"accessToken\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...\",\n  \"refreshToken\": \"a1b2c3d4e5f6...\",\n  \"user\": {\n    \"id\": \"507f1f77bcf86cd799439011\",\n    \"name\": \"Test User\",\n    \"email\": \"test@example.com\",\n    \"role\": \"user\"\n  }\n}"
            }
          ]
        },
        {
          "name": "2. Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Save tokens for later use",
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.environment.set('accessToken', jsonData.accessToken);",
                  "    pm.environment.set('refreshToken', jsonData.refreshToken);",
                  "    console.log('Tokens saved to environment');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "http://localhost:3001/auth/login",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3001",
              "path": ["auth", "login"]
            },
            "description": "Login with email and password. Returns accessToken (15min) and refreshToken (7 days)."
          },
          "response": [
            {
              "name": "Success Response",
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "body": "{\n  \"success\": true,\n  \"message\": \"Đăng nhập thành công\",\n  \"accessToken\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...\",\n  \"refreshToken\": \"a1b2c3d4e5f6...\",\n  \"user\": {\n    \"id\": \"507f1f77bcf86cd799439011\",\n    \"name\": \"Test User\",\n    \"email\": \"test@example.com\",\n    \"role\": \"user\"\n  }\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Refresh Token Management",
      "item": [
        {
          "name": "3. Refresh Access Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Update tokens after refresh",
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.environment.set('accessToken', jsonData.accessToken);",
                  "    pm.environment.set('refreshToken', jsonData.refreshToken);",
                  "    console.log('Tokens refreshed and updated');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": {
              "raw": "http://localhost:3001/auth/refresh",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3001",
              "path": ["auth", "refresh"]
            },
            "description": "Use refresh token to get a new access token. If ROTATE_REFRESH_TOKEN=true, also returns new refresh token."
          },
          "response": [
            {
              "name": "Success Response",
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "body": "{\n  \"success\": true,\n  \"message\": \"Token refreshed successfully\",\n  \"accessToken\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...\",\n  \"refreshToken\": \"new_refresh_token_here...\"\n}"
            },
            {
              "name": "Invalid Token",
              "status": "Unauthorized",
              "code": 401,
              "_postman_previewlanguage": "json",
              "body": "{\n  \"success\": false,\n  \"message\": \"Invalid refresh token\",\n  \"error\": \"TOKEN_NOT_FOUND\"\n}"
            },
            {
              "name": "Token Expired",
              "status": "Unauthorized",
              "code": 401,
              "_postman_previewlanguage": "json",
              "body": "{\n  \"success\": false,\n  \"message\": \"Refresh token has expired\",\n  \"error\": \"TOKEN_EXPIRED\"\n}"
            }
          ]
        },
        {
          "name": "4. Logout (Revoke Token)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": {
              "raw": "http://localhost:3001/auth/logout",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3001",
              "path": ["auth", "logout"]
            },
            "description": "Logout and revoke the refresh token in database."
          },
          "response": [
            {
              "name": "Success Response",
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "body": "{\n  \"success\": true,\n  \"message\": \"Logged out successfully\"\n}"
            }
          ]
        },
        {
          "name": "5. Get User Tokens",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "http://localhost:3001/auth/tokens",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3001",
              "path": ["auth", "tokens"]
            },
            "description": "Get list of all active refresh tokens for current user (Protected route)."
          },
          "response": [
            {
              "name": "Success Response",
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "body": "{\n  \"success\": true,\n  \"count\": 2,\n  \"tokens\": [\n    {\n      \"token\": \"a1b2c3d4e5...\",\n      \"createdAt\": \"2025-10-23T10:30:00.000Z\",\n      \"expiresAt\": \"2025-10-30T10:30:00.000Z\",\n      \"isActive\": true,\n      \"revokedAt\": null,\n      \"createdByIp\": \"127.0.0.1\"\n    }\n  ]\n}"
            }
          ]
        },
        {
          "name": "6. Revoke Specific Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"specific_token_to_revoke\"\n}"
            },
            "url": {
              "raw": "http://localhost:3001/auth/revoke-token",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3001",
              "path": ["auth", "revoke-token"]
            },
            "description": "Revoke a specific refresh token (user can revoke their own, admin can revoke any)."
          },
          "response": [
            {
              "name": "Success Response",
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "body": "{\n  \"success\": true,\n  \"message\": \"Token revoked successfully\"\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Protected Routes",
      "item": [
        {
          "name": "7. Get Profile",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "http://localhost:3001/profile",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3001",
              "path": ["profile"]
            },
            "description": "Get current user profile (requires valid access token)."
          },
          "response": [
            {
              "name": "Success Response",
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "body": "{\n  \"message\": \"Profile fetched\",\n  \"user\": {\n    \"id\": \"507f1f77bcf86cd799439011\",\n    \"name\": \"Test User\",\n    \"email\": \"test@example.com\",\n    \"role\": \"user\"\n  }\n}"
            },
            {
              "name": "Token Expired",
              "status": "Unauthorized",
              "code": 401,
              "_postman_previewlanguage": "json",
              "body": "{\n  \"success\": false,\n  \"message\": \"Access token expired\",\n  \"error\": \"TOKEN_EXPIRED\"\n}"
            }
          ]
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3001",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "refreshToken",
      "value": "",
      "type": "string"
    }
  ]
}
