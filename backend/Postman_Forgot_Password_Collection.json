{
  "info": {
    "name": "Forgot Password & Reset Password API",
    "description": "Complete API collection for testing password reset functionality",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3001",
      "type": "string"
    },
    {
      "key": "testEmail", 
      "value": "resettest@example.com",
      "type": "string"
    },
    {
      "key": "resetToken",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1️⃣ Setup & Authentication",
      "item": [
        {
          "name": "Register Test User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    console.log('✅ User registered successfully');",
                  "} else if (pm.response.code === 409) {",
                  "    console.log('ℹ️ User already exists, continuing...');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Reset Test User\",\n  \"email\": \"{{testEmail}}\",\n  \"password\": \"Test123!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/signup",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "signup"]
            },
            "description": "Register test user for password reset testing"
          }
        }
      ]
    },
    {
      "name": "2️⃣ Forgot Password Flow",
      "item": [
        {
          "name": "Request Password Reset",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const responseJson = pm.response.json();",
                  "    if (responseJson.resetToken) {",
                  "        pm.environment.set('resetToken', responseJson.resetToken);",
                  "        console.log('🎫 Reset token saved:', responseJson.resetToken);",
                  "        console.log('🔗 Reset URL:', responseJson.resetUrl);",
                  "    }",
                  "    console.log('✅ Password reset requested successfully');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type", 
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{testEmail}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/forgot-password",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "forgot-password"]
            },
            "description": "Request password reset - generates reset token"
          }
        },
        {
          "name": "Validate Reset Token", 
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/auth/validate-reset-token/{{resetToken}}",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "validate-reset-token", "{{resetToken}}"]
            },
            "description": "Validate if reset token is valid and not expired"
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw", 
              "raw": "{\n  \"password\": \"NewPassword123!\",\n  \"confirmPassword\": \"NewPassword123!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/reset-password/{{resetToken}}",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "reset-password", "{{resetToken}}"]
            },
            "description": "Reset password using the reset token"
          }
        },
        {
          "name": "Login with New Password",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{testEmail}}\",\n  \"password\": \"NewPassword123!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            },
            "description": "Verify password reset by logging in with new password"
          }
        }
      ]
    },
    {
      "name": "3️⃣ Error Testing",
      "item": [
        {
          "name": "Forgot Password - Invalid Email",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"nonexistent@example.com\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/forgot-password", 
              "host": ["{{baseUrl}}"],
              "path": ["auth", "forgot-password"]
            },
            "description": "Test forgot password with non-existent email (should not reveal if email exists)"
          }
        },
        {
          "name": "Validate Invalid Token",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/auth/validate-reset-token/invalid-token-12345",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "validate-reset-token", "invalid-token-12345"]
            },
            "description": "Test validation with invalid token - should return 400"
          }
        },
        {
          "name": "Reset Password - Invalid Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"password\": \"ValidPassword123!\",\n  \"confirmPassword\": \"ValidPassword123!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/reset-password/invalid-token-12345",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "reset-password", "invalid-token-12345"]
            },
            "description": "Test password reset with invalid token - should return 400"
          }
        },
        {
          "name": "Reset Password - Mismatched Passwords",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Generate new reset token for this test",
                  "pm.sendRequest({",
                  "    url: pm.environment.get('baseUrl') + '/auth/forgot-password',", 
                  "    method: 'POST',",
                  "    header: {'Content-Type': 'application/json'},",
                  "    body: {",
                  "        mode: 'raw',",
                  "        raw: JSON.stringify({email: pm.environment.get('testEmail')})",
                  "    }",
                  "}, function (err, response) {",
                  "    if (!err && response.json().resetToken) {",
                  "        pm.environment.set('tempResetToken', response.json().resetToken);",
                  "    }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type", 
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"password\": \"Password1\",\n  \"confirmPassword\": \"Password2\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/reset-password/{{tempResetToken}}",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "reset-password", "{{tempResetToken}}"]
            },
            "description": "Test password reset with mismatched passwords - should return 400"
          }
        },
        {
          "name": "Reset Password - Weak Password",
          "event": [
            {
              "listen": "prerequest", 
              "script": {
                "exec": [
                  "// Generate new reset token for this test",
                  "pm.sendRequest({",
                  "    url: pm.environment.get('baseUrl') + '/auth/forgot-password',",
                  "    method: 'POST',", 
                  "    header: {'Content-Type': 'application/json'},",
                  "    body: {",
                  "        mode: 'raw',",
                  "        raw: JSON.stringify({email: pm.environment.get('testEmail')})",
                  "    }",
                  "}, function (err, response) {",
                  "    if (!err && response.json().resetToken) {",
                  "        pm.environment.set('tempResetToken2', response.json().resetToken);",
                  "    }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"password\": \"123\",\n  \"confirmPassword\": \"123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/reset-password/{{tempResetToken2}}",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "reset-password", "{{tempResetToken2}}"]
            },
            "description": "Test password reset with weak password - should return 400"
          }
        }
      ]
    }
  ]
}